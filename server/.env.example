PORT=8787
NODE_ENV=production
DATABASE_URL=postgresql://idol_mode:change-me@your-rds-host:5432/idol_mode
DB_SSL=false
DB_POOL_MAX=10
# Keep true during local/manual testing. Set to false before public launch.
ALLOW_INSECURE_USER_ID_HEADER=true
AI_PROVIDER=qwen
DASHSCOPE_API_KEY=sk-your-dashscope-key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_ASR_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.5-flash
QWEN_ASR_MODEL=qwen3-asr-flash
IMAGE_CAPTION_MODEL=qwen3.5-flash
QWEN_TEMPERATURE=1.05
QWEN_MAX_TOKENS=900
RATE_LIMIT_PER_MINUTE=90
SLOW_REQUEST_MS=3000
WEB_CONCURRENCY=max
MAX_MEMORY_RESTART=300M
LOG_DIR=/opt/idol-mode/server/logs
ALLOWED_ORIGINS=*
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=180d
EMAIL_HASH_SECRET=replace-with-a-different-long-random-secret
EMAIL_ENCRYPTION_KEY=replace-with-32-byte-base64-or-long-secret
EMAIL_CODE_SECRET=replace-with-another-long-random-secret
EMAIL_DEV_MODE=false
# options: mock, aliyun_smtp, resend, webhook
EMAIL_PROVIDER=mock
EMAIL_FROM=Idol Mode <no-reply@your-domain.com>
EMAIL_CODE_SUBJECT=你的爱豆体验验证码
ALIYUN_DM_SMTP_HOST=smtpdm.aliyun.com
ALIYUN_DM_SMTP_PORT=465
ALIYUN_DM_SMTP_SECURE=true
ALIYUN_DM_SMTP_USER=your-directmail-smtp-user
ALIYUN_DM_SMTP_PASS=your-directmail-smtp-password
RESEND_API_KEY=your-resend-key
EMAIL_WEBHOOK_URL=https://your-mail-service.example/send
EMAIL_WEBHOOK_SECRET=your-mail-webhook-secret
OSS_ACCESS_KEY_ID=your-oss-access-key-id
OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret
OSS_BUCKET=your-oss-bucket
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_PUBLIC_BASE_URL=https://your-oss-bucket.oss-cn-hangzhou.aliyuncs.com
OSS_SIGN_EXPIRES_SECONDS=600
