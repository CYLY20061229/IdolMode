{
  "expo": {
    "name": "Idol Mode",
    "slug": "idol-mode",
    "scheme": "idolmode",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#FFF9FB"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.idolmode.app"
    },
    "android": {
      "package": "com.idolmode.app",
      "versionCode": 1,
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "backgroundColor": "#FFF9FB"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-av",
      [
        "expo-image-picker",
        {
          "photosPermission": "Idol Mode 需要访问相册，用于上传头像、聊天图片和表情包。",
          "cameraPermission": "Idol Mode 需要访问相机，用于拍照发送图片。"
        }
      ]
    ],
    "experiments": {},
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "58903b9a-e25e-482d-aed1-d8804eef4e28"
      }
    },
    "owner": "chenyang1111"
  }
}
